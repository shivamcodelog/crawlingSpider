# ════════════════════════════════════════════════════════════
#   MapScraper Pro — Environment Variables
#   Copy this file to .env and fill in your real credentials.
#   NEVER commit .env — it is listed in .gitignore
# ════════════════════════════════════════════════════════════

# ── MongoDB ──
# Local:      mongodb://localhost:27017/mapscraper
# Production: mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/?appName=<app>
MONGO_URI=mongodb://localhost:27017/mapscraper

# ── JWT ──
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_jwt_secret_key_change_me_in_production

# ── Google OAuth 2.0 ──
# Console: https://console.cloud.google.com → Credentials → OAuth 2.0 Client IDs
# Authorized redirect URIs:
#   Local:      http://localhost:5000/auth/google/callback
#   Production: https://your-backend.vercel.app/auth/google/callback
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:5000/auth/google/callback

# ── Razorpay (India payments) ──
# Dashboard: https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# ── Stripe (International payments) ──
# Dashboard: https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx

# ── Service URLs ──
# Local development:
SCRAPER_URL=http://localhost:8000
BACKEND_URL=http://localhost:5000
# Comma-separated for multiple CORS origins:
FRONTEND_URL=http://localhost:3000

# Production (replace with your deployed URLs):
# SCRAPER_URL=https://your-scraper.up.railway.app
# BACKEND_URL=https://your-backend.vercel.app
# FRONTEND_URL=https://your-frontend.vercel.app,http://localhost:3000

# ── Node ──
NODE_ENV=development
PORT=5000

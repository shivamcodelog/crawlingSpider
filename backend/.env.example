# ═══════════════════════════════════════════════
#   MapScraper Pro — Backend Environment Variables
#   Copy to .env and fill in real values
#   NEVER commit your real .env to git
# ═══════════════════════════════════════════════

MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/?appName=appName
JWT_SECRET=generate_with_node_crypto_randomBytes_64_hex
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=https://your-backend.azurewebsites.net/auth/google/callback
FRONTEND_URL=https://your-frontend.vercel.app
SCRAPER_URL=https://your-scraper.azurecontainer.io:8000
INTERNAL_SECRET=generate_with_node_crypto_randomBytes_32_hex
BACKEND_URL=https://your-backend.azurewebsites.net
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxx
NODE_ENV=production
PORT=8080

# ═══════════════════════════════════════════════════════════
#   MapScraper Pro — Backend Environment Variables (production)
#   Copy this to .env and fill in real values
# ═══════════════════════════════════════════════════════════

# ── MongoDB ──
# Your MongoDB Atlas connection string
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?appName=<appName>

# ── JWT ──
# Long random string — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_me_to_a_long_random_string

# ── Google OAuth ──
# https://console.cloud.google.com/ → Credentials → OAuth 2.0 Client IDs
# Authorized redirect URI:  https://your-backend.vercel.app/auth/google/callback
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=https://your-backend.vercel.app/auth/google/callback

# ── Frontend URL (CORS + OAuth redirect) ──
# Comma-separated for multiple origins, e.g. dev + prod
FRONTEND_URL=https://your-frontend.vercel.app,http://localhost:3000

# ── Scraper microservice (Railway URL) ──
SCRAPER_URL=https://your-scraper.up.railway.app

# ── Backend's own URL (used for internal links) ──
BACKEND_URL=https://your-backend.vercel.app

# ── Razorpay ──
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# ── Stripe ──
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxx

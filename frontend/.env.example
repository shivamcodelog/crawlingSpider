# ═══════════════════════════════════════════════════════════
#   MapScraper Pro — Frontend Environment Variables (production)
#   In Vercel dashboard → Settings → Environment Variables
# ═══════════════════════════════════════════════════════════

# URL of your deployed backend (no trailing slash)
VITE_API_URL=https://your-backend.vercel.app

# Razorpay public key (safe to expose in frontend)
VITE_RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxxxxxx
